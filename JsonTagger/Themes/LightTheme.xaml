<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base surfaces -->
    <SolidColorBrush x:Key="BgCanvas"     Color="#F6F8FA"/>
    <SolidColorBrush x:Key="BgSurface"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgCard"       Color="#F0F2F5"/>
    <SolidColorBrush x:Key="BgHover"      Color="#E2E8F0"/>
    <SolidColorBrush x:Key="BgSelected"   Color="#3B82F633"/>
    <SolidColorBrush x:Key="BorderSubtle" Color="#D1D9E0"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"  Color="#1A202C"/>
    <SolidColorBrush x:Key="TextMuted"    Color="#64748B"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentCoral"  Color="#E53E3E"/>
    <SolidColorBrush x:Key="AccentAmber"  Color="#D97706"/>
    <SolidColorBrush x:Key="AccentTeal"   Color="#0D9488"/>
    <SolidColorBrush x:Key="AccentBlue"   Color="#3B82F6"/>
    <SolidColorBrush x:Key="AccentRed"    Color="#DC2626"/>

    <!-- Primary button foreground -->
    <SolidColorBrush x:Key="PrimaryBtnFg" Color="#FFFFFF"/>

</ResourceDictionary>
