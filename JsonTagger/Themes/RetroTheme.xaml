<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base surfaces -->
    <SolidColorBrush x:Key="BgCanvas"     Color="#5BA5A8"/>
    <SolidColorBrush x:Key="BgSurface"    Color="#4A9092"/>
    <SolidColorBrush x:Key="BgCard"       Color="#F5EDD8"/>
    <SolidColorBrush x:Key="BgHover"      Color="#E8DBBC"/>
    <SolidColorBrush x:Key="BgSelected"   Color="#1A527633"/>
    <SolidColorBrush x:Key="BorderSubtle" Color="#C8AA78"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"  Color="#1C1C1C"/>
    <SolidColorBrush x:Key="TextMuted"    Color="#D4860A"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentCoral"  Color="#C0392B"/>
    <SolidColorBrush x:Key="AccentAmber"  Color="#D4860A"/>
    <SolidColorBrush x:Key="AccentTeal"   Color="#2E7D6E"/>
    <SolidColorBrush x:Key="AccentBlue"   Color="#1A5276"/>
    <SolidColorBrush x:Key="AccentRed"    Color="#922B21"/>

    <!-- Primary button foreground (light text on deep teal) -->
    <SolidColorBrush x:Key="PrimaryBtnFg" Color="#F5EDD8"/>

    <!-- Badge backgrounds / borders -->
    <SolidColorBrush x:Key="BadgeBlueBg"      Color="#1A527622"/>
    <SolidColorBrush x:Key="BadgeBlueBorder"  Color="#1A527655"/>
    <SolidColorBrush x:Key="BadgeCoralBg"     Color="#C0392B22"/>
    <SolidColorBrush x:Key="BadgeCoralBorder" Color="#C0392B55"/>

</ResourceDictionary>
