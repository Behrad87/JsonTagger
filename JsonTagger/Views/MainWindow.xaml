<Window x:Class="JsonTagger.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="JSON Configuration Tagger"
        Height="860" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentAmber}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin"     Value="0,0,0,0"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgCanvas}"
            CornerRadius="8"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="28"
                              ShadowDepth="6" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- ── TITLE BAR ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgSurface}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <!-- gradient accent stripe at top -->
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FF6B6B" Offset="0"/>
                        <GradientStop Color="#FFD166" Offset="0.4"/>
                        <GradientStop Color="#06D6A0" Offset="0.7"/>
                        <GradientStop Color="#118AB2" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>0,0,0,2</Border.BorderThickness>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0">
                        <Border Width="22" Height="22"
                                CornerRadius="5"
                                Margin="0,0,9,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF6B6B" Offset="0"/>
                                    <GradientStop Color="#FFD166" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{}{}"
                                       Foreground="#0F0E17"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       FontFamily="Cascadia Code, Consolas"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="JSON Configuration Tagger"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button Style="{StaticResource ChromeBtn}"
                                Content="&#xE921;"
                                ToolTip="Minimize"
                                Click="MinimizeBtn_Click"/>
                        <Button Style="{StaticResource ChromeBtn}"
                                x:Name="MaxRestoreBtn"
                                Content="&#xE922;"
                                ToolTip="Maximize"
                                Click="MaxRestoreBtn_Click"/>
                        <Button Style="{StaticResource ChromeBtnClose}"
                                Content="&#xE8BB;"
                                ToolTip="Close"
                                Click="CloseBtn_Click"
                                Width="50"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── TOOLBAR ── -->
            <Border Grid.Row="1"
                    Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="📂  Select Files"
                                Style="{StaticResource ToolbarBtn}"
                                Command="{Binding BrowseFilesCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="📁  Select Folder"
                                Style="{StaticResource ToolbarBtn}"
                                Command="{Binding SelectFolderCommand}"
                                Margin="0,0,8,0"/>

                        <Separator Width="1" Height="20"
                                   Background="{StaticResource BorderSubtle}"
                                   Margin="4,0,12,0"/>

                        <Button Content="＋  Add Tag"
                                Style="{StaticResource ToolbarBtn}"
                                Command="{Binding AddTagCommand}"
                                Margin="0,0,8,0"/>
                        <Button Content="🗑  Clear Tags"
                                Style="{StaticResource ToolbarBtn}"
                                Command="{Binding ClearAllTagsCommand}"
                                Margin="0,0,8,0"/>

                        <Separator Width="1" Height="20"
                                   Background="{StaticResource BorderSubtle}"
                                   Margin="4,0,12,0"/>

                        <Button Content="👁  Preview"
                                Style="{StaticResource ToolbarBtn}"
                                Command="{Binding PreviewCommand}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="✓  Apply Changes"
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding ApplyTagsCommand}"/>
                </Grid>
            </Border>

            <!-- ── CONTENT ── -->
            <Grid Grid.Row="2" Margin="14,12,14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="180"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FILES -->
                <Border Grid.Row="0"
                        Background="{StaticResource BgSurface}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="6,6,0,0"
                                Padding="14,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="FILES" Style="{StaticResource SectionLabel}"/>
                                <Border Background="#118AB222"
                                        BorderBrush="#118AB255"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="7,1"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource AccentBlue}"
                                               FontSize="11" FontFamily="Segoe UI">
                                        <Run Text="{Binding Files.Count, Mode=OneWay}"/>
                                        <Run Text=" loaded"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Files}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="FILE PATH"
                                                    Binding="{Binding FilePath}"
                                                    Width="*"/>
                                <DataGridTemplateColumn Header="VALID" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="14">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                                <Setter Property="Text"       Value="✓"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentTeal}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                <Setter Property="Text"       Value="✗"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="SIZE"
                                                    Binding="{Binding FileSizeBytes, StringFormat={}{0:N0} B}"
                                                    Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- TAGS -->
                <Border Grid.Row="2"
                        Background="{StaticResource BgSurface}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="6,6,0,0"
                                Padding="14,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="TAGS" Style="{StaticResource SectionLabel}"/>
                                <Border Background="#FF6B6B22"
                                        BorderBrush="#FF6B6B55"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="7,1"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource AccentCoral}"
                                               FontSize="11" FontFamily="Segoe UI">
                                        <Run Text="{Binding Tags.Count, Mode=OneWay}"/>
                                        <Run Text=" entries"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding Tags}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SECTION"
                                                    Binding="{Binding Section, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="180"/>
                                <DataGridTextColumn Header="KEY"
                                                    Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="220"/>
                                <DataGridTextColumn Header="VALUE"
                                                    Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                    Width="*"/>
                                <DataGridTemplateColumn Header="" Width="44">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕"
                                                    Command="{Binding RemoveCommand}"
                                                    Width="28" Height="22"
                                                    FontSize="10"
                                                    Background="Transparent"
                                                    Foreground="{StaticResource AccentCoral}"
                                                    BorderThickness="0"
                                                    Cursor="Hand"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- PREVIEW -->
                <Border Grid.Row="4"
                        Background="{StaticResource BgSurface}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="6,6,0,0"
                                Padding="14,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PREVIEW" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="— first loaded file"
                                           Foreground="{StaticResource TextMuted}"
                                           FontSize="11"
                                           FontFamily="Segoe UI"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <TextBox Grid.Row="1"
                                 Text="{Binding JsonPreview, Mode=OneWay}"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 BorderThickness="0"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── STATUS BAR ── -->
            <Border Grid.Row="3"
                    Background="{StaticResource BgSurface}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8"
                    Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource TextMuted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusIsSuccess}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentTeal}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusIsSuccess}" Value="False">
                                            <Setter Property="Fill" Value="{StaticResource AccentCoral}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Working…"
                                   Foreground="{StaticResource AccentAmber}"
                                   FontSize="12"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>