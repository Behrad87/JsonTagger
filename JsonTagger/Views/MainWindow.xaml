<Window x:Class="JsonTagger.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="JSON Configuration Tagger"
        Height="850"
        Width="1400">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="250"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Buttons -->

        <StackPanel Orientation="Horizontal">

            <Button Content="Select Files"
                    Command="{Binding BrowseFilesCommand}"
                    Margin="5"/>

            <Button Content="Select Folder"
                    Command="{Binding SelectFolderCommand}"
                    Margin="5"/>

            <Button Content="Add Tag"
                    Command="{Binding AddTagCommand}"
                    Margin="5"/>

            <Button Content="Preview"
                    Command="{Binding PreviewCommand}"
                    Margin="5"/>

            <Button Content="Apply Changes"
                    Command="{Binding ApplyTagsCommand}"
                    Margin="5"/>

        </StackPanel>

        <!-- Files -->

        <GroupBox Header="Files"
                  Grid.Row="1"
                  Margin="0,10,0,10">

            <DataGrid ItemsSource="{Binding Files}"
                      AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="File"
                        Binding="{Binding FileName}"
                        Width="*"/>

                    <DataGridCheckBoxColumn
                        Header="Valid"
                        Binding="{Binding IsValid}"/>

                    <DataGridTextColumn
                        Header="Size"
                        Binding="{Binding FileSizeBytes}"/>

                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>

        <!-- Tags -->

        <GroupBox Header="Tags"
                  Grid.Row="2">

            <DataGrid ItemsSource="{Binding Tags}"
                      AutoGenerateColumns="False">

                <DataGrid.Columns>

                    <DataGridTextColumn
                        Header="Section"
                        Binding="{Binding Section}"
                        Width="150"/>

                    <DataGridTextColumn
                        Header="Key"
                        Binding="{Binding Key}"
                        Width="200"/>

                    <DataGridTextColumn
                        Header="Value"
                        Binding="{Binding Value}"
                        Width="*"/>

                </DataGrid.Columns>

            </DataGrid>

        </GroupBox>

        <!-- Preview -->

        <GroupBox Header="Preview"
                  Grid.Row="3"
                  Margin="0,10,0,0">

            <TextBox Text="{Binding JsonPreview}"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"/>

        </GroupBox>

    </Grid>
</Window>